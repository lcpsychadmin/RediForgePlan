{
  "name": "rediforge-server",
  "version": "1.0.0",
  "description": "Express backend for RediForge",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "nodemon --exec node --loader tsx src/server.ts",
    "build": "tsc --noEmit false --skipLibCheck || true",
    "start": "node dist/server.js",
    "lint": "eslint . --ext ts --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "morgan": "^1.10.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3",
    "uuid": "^9.0.0",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/cors": "^2.8.13",
    "@types/morgan": "^1.9.5",
    "@types/bcryptjs": "^2.4.2",
    "@types/jsonwebtoken": "^9.0.2",
    "@types/speakeasy": "^2.0.8",
    "@types/qrcode": "^1.5.2",
    "typescript": "^5.1.0",
    "nodemon": "^3.0.1",
    "ts-node": "^10.9.1",
    "tsx": "^3.13.0",
    "eslint": "^8.44.0"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
