NODE_ENV=development
PORT=5000
DATABASE_URL=postgresql://user:password@localhost:5432/rediforge

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# MFA Encryption (32-byte key for AES-256)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Optional testing helper (DISABLED by default)
# When enabled, /auth/auto-login issues an admin token for AUTO_LOGIN_ADMIN_EMAIL.
AUTO_LOGIN_ENABLED=false
AUTO_LOGIN_ADMIN_EMAIL=admin@rediforge.com

# Optional build helper (DISABLED by default)
# When enabled, /auth/build-access accepts a shared key and returns a user token.
BUILD_ACCESS_ENABLED=false
BUILD_ACCESS_KEY=replace-with-long-random-shared-key
BUILD_ACCESS_EMAIL=admin@rediforge.com
